{
  "pages": {
    "/(site)/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(site)/page.css",
      "static/chunks/app/(site)/page.js"
    ],
    "/(site)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(site)/layout.css",
      "static/chunks/app/(site)/layout.js"
    ],
    "/(site)/not-found": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(site)/not-found.js"
    ],
    "/(site)/joint-ventures/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(site)/joint-ventures/page.js"
    ],
    "/admin/login/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/admin/login/page.js"
    ],
    "/admin/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/admin/layout.css",
      "static/chunks/app/admin/layout.js"
    ],
    "/admin/(dashboard)/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/admin/(dashboard)/page.js"
    ],
    "/admin/(dashboard)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/admin/(dashboard)/layout.js"
    ],
    "/admin/(dashboard)/joint-ventures/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/admin/(dashboard)/joint-ventures/page.js"
    ],
    "/admin/(dashboard)/joint-ventures/[id]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/admin/(dashboard)/joint-ventures/[id]/page.js"
    ],
    "/_not-found/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/_not-found/page.js"
    ]
