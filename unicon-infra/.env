# Copy this file to .env and update the values.

# --- Admin Panel Login ---
# Default login (CHANGE THIS before deploying):
#   email:    admin@uniconinfra.com
#   password: Admin@123
#
# To set your own password, run:
#   node scripts/hash-password.js "yourNewPassword"
# then paste the printed hash below.
#
# IMPORTANT: bcrypt hashes contain "$" characters, which Next.js's env
# loader treats as variable references. Escape every "$" as "\$" here
# (as already done below) or the hash will get silently corrupted.
ADMIN_EMAIL=admin@uniconinfra.com
ADMIN_PASSWORD_HASH=\$2a\$10\$kXBPuAK2Vie/Ld9ZxIAcv.ZiYa.37eFK2y/8JrfWpb26NxdMbwkYq

# --- Session Signing Secret ---
# Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=replace-this-with-a-long-random-string-before-deploying
